# Convex
CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site
CONVEX_DEPLOYMENT=dev:your-deployment-name
CONVEX_SERVER_ACCESS_KEY=replace-with-high-entropy-shared-secret

# App auth/session
AUTH_SECRET=replace-with-at-least-32-characters
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gemini (existing provider)
GEMINI_API_KEY=replace-with-gemini-api-key

# Replicate (optional provider for image/video/audio)
REPLICATE_API_TOKEN=replace-with-replicate-api-token
REPLICATE_IMAGE_MODEL=google/imagen-4
REPLICATE_VIDEO_MODEL=minimax/video-01
REPLICATE_AUDIO_MODEL=resemble-ai/chatterbox
